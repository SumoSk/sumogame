    return '#111111';
  }

  function laneCapacityAt(i) {
    const rd = roadDataById(road[i]);
    return rd ? rd.lanes : 0;
  }
  function cellVehicleCount(i) {
    const set = laneMap.get(i);
    return set ? set.size : 0;
  }
  function canEnterCell(i, vehicleId) {
    if (!road[i]) return false;
    const set = laneMap.get(i);
    if (!set || (vehicleId > 0 && set.has(vehicleId))) return true;
    return set.size < laneCapacityAt(i);
  }
  function occupyCell(i, vehicleId) {
    if (!road[i]) return false;
    let set = laneMap.get(i);
    if (!set) { set = new Set(); laneMap.set(i, set); }
    if (set.has(vehicleId)) return true;
    if (set.size >= laneCapacityAt(i)) return false;
    set.add(vehicleId);
    occ[i] = [...set][0] || 0;
    return true;
  }
  function releaseCell(i, vehicleId) {
    const set = laneMap.get(i);
    if (!set) { occ[i] = 0; return; }
    set.delete(vehicleId);
    if (!set.size) { laneMap.delete(i); occ[i] = 0; }
    else occ[i] = [...set][0] || 0;
  }
  function clearNextCell(v) {
    if (v.nextIdx != null) {
      releaseCell(v.nextIdx, v.id);
      v.nextIdx = null;
      v.t = 0;
    }
  }

  function ensureRoadLinkSet(i) {
    let set = roadLinks.get(i);
    if (!set) { set = new Set(); roadLinks.set(i, set); }
    return set;
  }
  function addRoadLink(a, b) {
    if (a === b || !road[a] || !road[b]) return false;
    const ax = a % MAP_W, ay = Math.floor(a / MAP_W);
    const bx = b % MAP_W, by = Math.floor(b / MAP_W);
    if (Math.max(Math.abs(ax - bx), Math.abs(ay - by)) !== 1) return false;
    ensureRoadLinkSet(a).add(b);
    ensureRoadLinkSet(b).add(a);
    connCache[a] = countConnections(ax, ay);
    connCache[b] = countConnections(bx, by);
    return true;
  }
  function removeRoadLinks(i) {
    const set = roadLinks.get(i);
    if (set) {
      for (const n of set) {
        const ns = roadLinks.get(n);
        if (ns) {
          ns.delete(i);
          const p = xy(n);
          connCache[n] = countConnections(p.x, p.y);
          if (!ns.size) roadLinks.delete(n);
        }
      }
    }
    roadLinks.delete(i);
    connCache[i] = 0;
  }
  function linkedNeighbors(i) {
    const set = roadLinks.get(i);
    if (!set) return [];
    return [...set].filter(n => road[n]);
  }
  function linkRoadCellsInOrder(cells) {
    for (let k = 1; k < cells.length; k++) addRoadLink(cells[k - 1], cells[k]);
    pathCache.clear();
    roadVersion++;
  }

  function vehicleLaneIndex(v, cellIdx) {
    const lanes = Math.max(1, laneCapacityAt(cellIdx));
    const set = laneMap.get(cellIdx);
    if (!set) return Math.abs(v.id) % lanes;
    const arr = [...set].sort((a,b) => a - b);
    const pos = arr.indexOf(v.id);
    return pos >= 0 ? pos % lanes : Math.abs(v.id) % lanes;
  }

