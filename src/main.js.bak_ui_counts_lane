  }

  function placeRoadCells(cells, roadKey, charge=true) {
    const placed = [];
    for (const i of cells) {
      const p = xy(i);
      if (placeRoadCell(p.x, p.y, roadKey, charge)) placed.push(i);
    }
    linkRoadCellsInOrder(placed);
    for (const i of placed) {
      const p = xy(i);
      recomputeConnectionsAround(p.x, p.y, 2);
    }
    updateGateEntrances();
    return placed.length;
  }

