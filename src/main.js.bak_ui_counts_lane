            : trait === 'บ้านรวย'
              ? ['mall', 'restaurant', 'pub'][i % 3]
              : ['restaurant', 'mall', 'pub', 'shop', 'park'][i % 5];
      profiles.push({
        id: i + 1,
        trait,
        tax: trait === 'สายชิล' ? 700 : trait === 'บ้านรวย' ? 1500 : 1000,
