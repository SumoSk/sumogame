    addAlert('แผนที่เปล่า', `เมือง ${city.name}: เริ่มด้วยพื้นที่ว่าง ไม่มีถนนหรืออาคารอัตโนมัติ ให้ลากถนนจาก Gate แล้วค่อยวางบ้าน/งาน`, 1, 'good');
    setStatus('แผนที่เปล่า: เริ่มจากลากถนนจาก Gate แล้ววางบ้าน/อาคารติดถนน');
  }

  function addGate(data) {
    const gate = { id: gates.length + 1, ...data, entrance: null, inToday: 0, outToday: 0, passToday: 0 };
    gates.push(gate);
    return gate;
  }

  function isGateCell(x, y) {
    return gates.find(g => Math.abs(g.x - x) <= 1 && Math.abs(g.y - y) <= 1);
  }

  function updateGateEntrances() {
    for (const g of gates) {
      let best = null;
      let bestD = Infinity;
      for (let dy = -4; dy <= 4; dy++) for (let dx = -4; dx <= 4; dx++) {
        const x = g.x + dx, y = g.y + dy;
        if (!inBounds(x, y)) continue;
        const i = idx(x, y);
        if (!road[i]) continue;
        const d = Math.abs(dx) + Math.abs(dy);
        if (d < bestD) { bestD = d; best = i; }
      }
      g.entrance = best;
    }
  }

  function recomputeConnectionsAround(x, y, radius = 2) {
    for (let yy = y - radius; yy <= y + radius; yy++) for (let xx = x - radius; xx <= x + radius; xx++) {
      if (!inBounds(xx, yy)) continue;
      const i = idx(xx, yy);
      connCache[i] = countConnections(xx, yy);
    }
  }
  function countConnections(x, y, roadsOverride = null) {
    const i = idx(x, y);
    const hasRoad = roadsOverride ? roadsOverride.has(i) || road[i] : road[i];
    if (!hasRoad) return 0;
    if (!roadsOverride) return linkedNeighbors(i).length;
    // During preview/checking, count possible branches conservatively so junctions stay <= 4 ways.
    let c = 0;
    for (const [dx, dy] of DIRS) {
      const nx = x + dx, ny = y + dy;
      if (!inBounds(nx, ny)) continue;
      const ni = idx(nx, ny);
      if (roadsOverride.has(ni) || road[ni]) c++;
    }
    return c;
  }

  function canAddRoadCells(cells) {
    const addSet = new Set(cells);
    const toCheck = new Set();
    for (const i of cells) {
      const {x, y} = xy(i);
      toCheck.add(i);
      for (const [dx, dy] of DIRS) {
        const nx = x + dx, ny = y + dy;
        if (inBounds(nx, ny)) toCheck.add(idx(nx, ny));
      }
    }
    for (const i of toCheck) {
      const p = xy(i);
      if (countConnections(p.x, p.y, addSet) > 4) return { ok: false, reason: 'ทางแยกเกิน 4 ขา' };
    }
    return { ok: true };
  }

  function placeRoadCell(x, y, roadKey = 'small', charge = true) {
    if (!inBounds(x, y)) return false;
    const i = idx(x, y);
    const rd = DATA.roads[roadKey];
    const old = road[i];
    const oldRd = roadDataById(old);
    if (old && old >= rd.id) return true;
    const deltaCost = oldRd ? Math.max(0, rd.cost - oldRd.cost) : rd.cost;
    if (charge && !canSpend(deltaCost)) return false;
    if (!old) game.roadCount++;
    road[i] = rd.id;
    if (charge) game.money -= deltaCost;
    recomputeConnectionsAround(x, y, 2);
    pathCache.clear();
    roadVersion++;
    updateGateEntrances();
    return true;
  }

  function removeRoadCell(x, y, charge = true) {
    if (!inBounds(x, y)) return false;
    const i = idx(x, y);
    if (!road[i]) return false;
    if (cellVehicleCount(i) > 0) return false;
    const oldRd = roadDataById(road[i]);
    const fee = oldRd.cost * 0.2;
    if (charge) game.money -= fee;
    removeRoadLinks(i);
    road[i] = 0;
    game.roadCount = Math.max(0, game.roadCount - 1);
    recomputeConnectionsAround(x, y, 2);
    pathCache.clear();
    roadVersion++;
    updateGateEntrances();
    return true;
  }

  function getLineCells(x0, y0, x1, y1) {
    if (!inBounds(x0, y0) || !inBounds(x1, y1)) return [];
    let dx = x1 - x0, dy = y1 - y0;
    if (dx === 0 && dy === 0) return [idx(x0, y0)];
    const adx = Math.abs(dx), ady = Math.abs(dy);
    let sx = sign(dx), sy = sign(dy);
    if (adx > ady * 2) sy = 0;
    else if (ady > adx * 2) sx = 0;
    else { sx = sign(dx); sy = sign(dy); }
    const steps = sy === 0 ? adx : sx === 0 ? ady : Math.max(adx, ady);
    const cells = [];
    let x = x0, y = y0;
    for (let s = 0; s <= steps; s++) {
      if (inBounds(x, y)) cells.push(idx(x, y));
      x += sx; y += sy;
    }
    return [...new Set(cells)];
  }

  function canSpend(cost) {
    if (game.money < 0) return false;
    return game.money - cost >= -10000;
  }

  function addBuilding(typeKey, x, y, charge = true) {
    const t = DATA.buildings[typeKey];
    const check = canPlaceBuilding(typeKey, x, y, charge);
    if (!check.ok) return check;
    if (charge) game.money -= t.cost;
    const b = {
      id: nextBuildingId++, typeKey, kind: t.kind, name: t.name,
      x, y, w: t.w, h: t.h,
      residents: 0, reservedResidents: 0,
      employees: 0, reservedService: 0, visitors: 0,
      workerIds: [], citizenIds: [],
      entrance: check.entrance,
      builtAt: game.worldMin,
      arrivals: 0, fails: 0
    };
    buildings.push(b);
    for (let yy = y; yy < y + t.h; yy++) for (let xx = x; xx < x + t.w; xx++) buildGrid[idx(xx, yy)] = b.id;
    if (charge) setStatus(`วาง ${t.name} ราคา ${formatMoney(t.cost)} บาท`);
    assignJobs();
    return { ok: true, building: b };
  }

  function canPlaceBuilding(typeKey, x, y, checkMoney = true) {
    const t = DATA.buildings[typeKey];
    if (!t) return { ok:false, reason:'ไม่มีข้อมูลอาคาร' };
    if (x < 1 || y < 1 || x + t.w >= MAP_W - 1 || y + t.h >= MAP_H - 1) return { ok:false, reason:'พื้นที่เกินขอบแมป' };
    if (checkMoney && !canSpend(t.cost)) return { ok:false, reason:'เงินไม่พอ หรือเงินติดลบอยู่' };
    for (let yy = y; yy < y + t.h; yy++) for (let xx = x; xx < x + t.w; xx++) {
      const i = idx(xx, yy);
      if (road[i]) return { ok:false, reason:'พื้นที่ทับถนน' };
      if (buildGrid[i]) return { ok:false, reason:'พื้นที่ทับสิ่งก่อสร้าง' };
    }
    const entrance = findAdjacentRoadForRect(x, y, t.w, t.h);
    if (entrance == null) return { ok:false, reason:'อาคารต้องติดถนนและมีทางเข้าออก' };
    return { ok:true, entrance };
  }

  function findAdjacentRoadForRect(x, y, w, h) {
    let best = null;
    let bestScore = Infinity;
    for (let yy = y - 1; yy <= y + h; yy++) for (let xx = x - 1; xx <= x + w; xx++) {
      if (!inBounds(xx, yy)) continue;
      const outside = xx < x || xx >= x + w || yy < y || yy >= y + h;
      if (!outside) continue;
      const i = idx(xx, yy);
      if (road[i]) {
        const score = Math.abs(xx - (x + w / 2)) + Math.abs(yy - (y + h / 2));
        if (score < bestScore) { bestScore = score; best = i; }
      }
    }
    return best;
  }

