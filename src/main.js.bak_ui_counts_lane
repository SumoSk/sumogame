  function makeProfiles() {
    const profiles = [];
    for (let i = 0; i < 100; i++) {
      let trait = 'ขยัน';
      if (i >= 45 && i < 75) trait = 'ชิล ๆ';
      else if (i >= 75 && i < 90) trait = 'สายชิล';
      else if (i >= 90 && i < 97) trait = 'บ้านรวย';
      else if (i >= 97) trait = 'มนุษย์พิเศษ';

      const baseLeave = 6 * 60 + 20 + (i * 11) % 200;
      const workEnd = 17 * 60 + 30 + (i * 17) % 90;
      const leisureKind = trait === 'ขยัน'
        ? (i % 8 === 0 ? 'park' : null)
        : trait === 'ชิล ๆ'
          ? ['restaurant', 'mall', null, 'shop'][i % 4]
          : trait === 'สายชิล'
