  function scheduleDailyMaintenance() {
    pushEvent(nextAbsMinute(0), 'daily', null);
  }

  function pushEvent(time, type, payload) {
    events.push({ time, type, payload });
    if (events.length > 1 && events[events.length - 2].time > time) {
      events.sort((a,b) => a.time - b.time);
    }
  }

  function processEvents() {
    if (events.length > 1 && events[0].time > events[1].time) events.sort((a,b) => a.time - b.time);
    let guard = 0;
    while (events.length && events[0].time <= game.worldMin && guard++ < 1500) {
      const ev = events.shift();
      handleEvent(ev);
    }
  }

  function handleEvent(ev) {
    if (ev.type === 'daily') {
      dailyTick();
      pushEvent(absAt(absDay() + 1, 0), 'daily', null);
      return;
    }
    const c = ev.payload && citizens.find(x => x.id === ev.payload.citizenId);
    if (!c || c.removed) return;
    if (ev.type === 'goWork') startWorkTrip(c, ev.payload.deadline);
    else if (ev.type === 'leaveWork') startAfterWork(c);
    else if (ev.type === 'weekendLeisure') startWeekendLeisure(c);
    else if (ev.type === 'richLeisure') startRichLeisure(c);
    else if (ev.type === 'returnHome') startReturnHome(c, ev.payload.reason || 'กลับบ้าน');
    else if (ev.type === 'moveOut') startMoveOut(c);
  }

  function dailyTick() {
    const stats = computeStats();
    const residentTax = citizens.filter(c => c.resident && !c.movingOut && !c.removed).reduce((s, c) => s + c.profile.tax, 0);
    const businessTax = buildings.reduce((s, b) => s + b.employees * 50, 0);
    const roadMaint = computeRoadMaintenance();
    const buildingMaint = buildings.reduce((s, b) => s + buildingType(b).maintenance, 0);
    game.money += residentTax + businessTax - roadMaint - buildingMaint;
    if (game.money < -10000) game.money = -10000;

    for (const g of gates) { g.inToday = 0; g.outToday = 0; g.passToday = 0; }
    for (const b of buildings) { b.arrivals = 0; b.fails = 0; }

    assignJobs();
    for (const c of citizens) {
      if (!c.resident || c.removed) continue;
      if (!c.workId && c.profile.workDays.length) c.unemployedDays++;
      else c.unemployedDays = 0;
      if (c.unemployedDays >= 2 && !c.movingOut) {
        c.satisfaction -= 28;
        addAlert('งานไม่พอ', `Citizen ${c.id} ไม่มีงานครบ 2 วันและเริ่มย้ายออก`, 1);
        c.movingOut = true;
        pushEvent(game.worldMin + 10 + (c.id % 30), 'moveOut', { citizenId: c.id });
      }
      if (c.satisfaction < 25 && !c.movingOut) {
        addAlert('ความพึงพอใจต่ำ', `Citizen ${c.id} ความสุขต่ำและเริ่มย้ายออก`, 1);
        c.movingOut = true;
        pushEvent(game.worldMin + 20 + (c.id % 40), 'moveOut', { citizenId: c.id });
      } else {
        c.satisfaction = Math.min(100, c.satisfaction + 2);
      }
      scheduleCitizenDay(c, absDay());
    }
    addAlert('สรุปรายวัน', `ภาษีประชากร +${formatMoney(residentTax)} / ธุรกิจ +${formatMoney(businessTax)} / บำรุง -${formatMoney(roadMaint + buildingMaint)}`, 1, 'good');
  }

  function scheduleCitizenDay(c, day) {
    if (!c.resident || c.removed || c.movingOut) return;
    if (c.scheduledDays && c.scheduledDays.has(day)) return;
    if (!c.scheduledDays) c.scheduledDays = new Set();
    c.scheduledDays.add(day);
    const wd = day % 7;
    const p = c.profile;
    if (p.trait === 'บ้านรวย') {
      pushEvent(absAt(day, p.richStart), 'richLeisure', { citizenId: c.id });
      c.scheduleNote = `บ้านรวย: ไม่ทำงาน • ออกเที่ยว ${minLabel(p.richStart)} → 03:00`;
      return;
    }
    if (p.workDays.includes(wd)) {
      pushEvent(absAt(day, p.leaveWorkAt), 'goWork', { citizenId: c.id, deadline: absAt(day, p.workStartDeadline) });
      pushEvent(absAt(day, p.workEndAt), 'leaveWork', { citizenId: c.id });
      c.scheduleNote = `${p.trait}: ไปทำงาน ${minLabel(p.leaveWorkAt)} • เลิกงาน ${minLabel(p.workEndAt)}${p.afterWork ? ` • หลังงาน: ${kindName(p.afterWork)}` : ''}`;
    } else if (p.weekendKind) {
      pushEvent(absAt(day, p.weekendStart), 'weekendLeisure', { citizenId: c.id });
      c.scheduleNote = `${p.trait}: วันไม่ทำงาน • ไป${kindName(p.weekendKind)} ${minLabel(p.weekendStart)}`;
    } else {
      c.scheduleNote = `${p.trait}: วันนี้อยู่บ้าน`;
    }
  }

  function createCitizen(homeId, resident = false) {
    const profile = DATA.profiles[profileCursor++ % DATA.profiles.length];
    const c = {
      id: nextCitizenId++,
      profile,
      homeId,
      workId: null,
      location: resident ? `building:${homeId}` : 'gate',
      state: resident ? 'อยู่บ้าน' : 'กำลังย้ายเข้า',
      satisfaction: 82,
      unemployedDays: 0,
      failCount: 0,
      resident,
      movingOut: false,
      removed: false,
      currentVehicleId: null,
      lastTrip: null,
      scheduledDays: new Set(),
      scheduleNote: ''
    };
    citizens.push(c);
    if (resident) {
      const h = buildingById(homeId);
      if (h) { h.residents++; h.citizenIds.push(c.id); }
      assignJobFor(c);
      scheduleCitizenDay(c, absDay());
    }
    return c;
  }

  function computeRoadMaintenance() {
    let m = 0;
    for (let i = 0; i < MAP_SIZE; i++) if (road[i]) m += roadDataById(road[i]).maintenance;
    return m;
  }

  function assignJobs() {
    for (const c of citizens) if (c.resident && !c.removed && !c.workId && c.profile.workDays.length) assignJobFor(c);
  }

  function assignJobFor(c) {
    if (!c.profile.workDays.length) return false;
    const home = buildingById(c.homeId);
    if (!home) return false;
    let best = null, bestD = Infinity;
    for (const b of buildings) {
      const t = buildingType(b);
      if (t.jobs <= 0) continue;
      if (b.employees >= t.jobs) continue;
      if (findPath(home.entrance, b.entrance, true).length === 0) continue;
      const d = Math.abs(home.x - b.x) + Math.abs(home.y - b.y);
      if (d < bestD) { bestD = d; best = b; }
    }
    if (!best) {
      c.workId = null;
      addAlert('งานไม่พอ', `ประชาชนบางส่วนไม่มีอาคารจ้างงานที่ถนนเชื่อมถึง`, 1);
      return false;
    }
    best.employees++;
    best.workerIds.push(c.id);
    c.workId = best.id;
    return true;
  }

  function immigrationManager(gameMinutes) {
    game.immigrationTick += gameMinutes;
    if (game.immigrationTick < 18) return;
    game.immigrationTick = 0;
    if (vehicles.length > MAX_ACTIVE_VEHICLES * 0.8) return;
    const home = findVacantHome();
    if (!home) return;
    const gate = chooseOpenGate();
    if (!gate || gate.entrance == null) {
      addAlert('ต้องการถนนเข้าเมือง', 'ไม่มี Gate ที่เชื่อมถนนเข้าบ้านว่างได้ คนย้ายเข้าไม่ได้', 1);
      return;
    }
    const c = createCitizen(home.id, false);
    home.reservedResidents++;
    const ok = createTrip({ citizen: c, fromIdx: gate.entrance, toIdx: home.entrance, type: 'MoveInTrip', deadline: game.worldMin + 1440, destBuildingId: home.id, gateId: gate.id });
    if (!ok) {
      home.reservedResidents--;
      c.removed = true;
      addAlert('คนย้ายเข้าไม่ถึงบ้าน', 'มีบ้านว่างแต่ไม่มีเส้นทางจาก City Gate ถึงบ้าน', 1);
    } else {
      gate.inToday++;
    }
  }

  function passThroughManager(gameMinutes) {
    game.passTick += gameMinutes;
    if (game.passTick < 28) return;
    game.passTick = 0;
    if (vehicles.length > MAX_ACTIVE_VEHICLES) return;
    const open = gates.filter(g => g.entrance != null);
    if (open.length < 2) return;
    const a = open[(Math.floor(game.worldMin / 30) + open.length) % open.length];
    const b = open[(Math.floor(game.worldMin / 47) + 1) % open.length];
    if (a.id === b.id) return;
    const path = findPath(a.entrance, b.entrance, true);
    if (!path.length) return;
    const ok = createTrip({ citizen: null, fromIdx: a.entrance, toIdx: b.entrance, type: 'PassThroughTrip', deadline: game.worldMin + 600, gateId: a.id, targetGateId: b.id, prePath: path });
    if (ok) { a.passToday++; b.passToday++; }
  }

  function findVacantHome() {
    return buildings.find(b => {
      const t = buildingType(b);
      return t.kind === 'home' && b.residents + b.reservedResidents < t.residents;
    });
  }
  function chooseOpenGate() {
    const open = gates.filter(g => g.entrance != null);
    if (!open.length) return null;
    return open[(Math.floor(game.worldMin / 18) + open.length) % open.length];
  }

  function startWorkTrip(c, deadline) {
    if (!c.resident || c.movingOut || c.currentVehicleId) return;
    if (!c.workId) {
      if (!assignJobFor(c)) {
        c.satisfaction -= 10;
        addAlert('งานไม่พอ', `Citizen ${c.id} ไม่มีที่ทำงาน จึงไม่สร้างรถลงถนน`, 1);
        return;
      }
    }
    const home = buildingById(c.homeId), work = buildingById(c.workId);
    if (!home || !work) return;
    c.state = 'กำลังไปทำงาน';
    createTrip({ citizen: c, fromIdx: home.entrance, toIdx: work.entrance, type: 'WorkTrip', deadline, destBuildingId: work.id });
  }

  function startAfterWork(c) {
    if (!c.resident || c.movingOut || c.currentVehicleId) return;
    const p = c.profile;
    if (p.afterWork && (p.trait !== 'ขยัน' || c.id % 6 === 0)) {
      startLeisure(c, p.afterWork, absAt(absDay(), p.afterWorkEnd), 'หลังเลิกงาน');
    } else {
      startReturnHome(c, 'เลิกงาน');
    }
  }
  function startWeekendLeisure(c) {
    if (!c.resident || c.movingOut || c.currentVehicleId) return;
    const p = c.profile;
    if (!p.weekendKind) return;
    startLeisure(c, p.weekendKind, absAt(absDay(), p.weekendEnd), 'วันหยุด');
  }
  function startRichLeisure(c) {
    if (!c.resident || c.movingOut || c.currentVehicleId) return;
    const p = c.profile;
    const kind = ['mall','restaurant','pub'][c.id % 3];
    const endAbs = absAt(absDay() + 1, 3 * 60);
    startLeisure(c, kind, endAbs, 'บ้านรวยเที่ยวกลางคืน');
  }

  function currentBuildingOf(c) {
    if (!c.location || !c.location.startsWith('building:')) return null;
    return buildingById(Number(c.location.split(':')[1]));
  }

  function startLeisure(c, kind, endAbs, reason) {
    const origin = currentBuildingOf(c) || buildingById(c.homeId);
    if (!origin) return;
    const target = findServiceBuilding(kind, origin.entrance);
    if (!target) {
      c.satisfaction -= 9;
      addAlert(`ต้องการ${kindName(kind)}`, `${reason}: ไม่มีอาคารหรือ Capacity ว่างสำหรับ ${kindName(kind)} จึงไม่สร้างรถ`, 1);
      if (origin.id !== c.homeId) startReturnHome(c, 'ปลายทางกิจกรรมเต็ม');
      return;
    }
    target.reservedService++;
    c.state = `กำลังไป${kindName(kind)}`;
    const ok = createTrip({ citizen: c, fromIdx: origin.entrance, toIdx: target.entrance, type: 'LeisureTrip', deadline: endAbs, destBuildingId: target.id, reservedService: true, activityEnd: endAbs });
    if (!ok) {
      target.reservedService--;
      c.satisfaction -= 12;
      addAlert('ไม่มีเส้นทางกิจกรรม', `${reason}: หาเส้นทางไป ${target.name} ไม่ได้`, 1);
    }
  }

  function kindName(kind) {
    return ({ shop:'ร้านค้า', restaurant:'ร้านอาหาร', mall:'ห้าง', park:'สวน', pub:'ผับ' })[kind] || kind;
  }

  function findServiceBuilding(kind, fromIdx) {
    let best = null, bestCost = Infinity;
    for (const b of buildings) {
      const t = buildingType(b);
      if (t.kind !== kind || t.service <= 0) continue;
      if (b.visitors + b.reservedService >= t.service) continue;
      const path = findPath(fromIdx, b.entrance, true);
      if (!path.length) continue;
      const cost = path.length + (b.visitors / Math.max(1, t.service)) * 20;
      if (cost < bestCost) { bestCost = cost; best = b; }
    }
    return best;
  }

  function startReturnHome(c, reason) {
    if (!c.resident || c.currentVehicleId || c.removed) return;
    const origin = currentBuildingOf(c) || buildingById(c.workId) || buildingById(c.homeId);
    const home = buildingById(c.homeId);
    if (!origin || !home || origin.id === home.id) {
      c.location = `building:${c.homeId}`;
      c.state = 'อยู่บ้าน';
      return;
    }
    if (origin.kind !== 'home' && buildingType(origin).service > 0) {
      origin.visitors = Math.max(0, origin.visitors - 1);
    }
    c.state = `กำลังกลับบ้าน (${reason})`;
    createTrip({ citizen: c, fromIdx: origin.entrance, toIdx: home.entrance, type: 'ReturnHomeTrip', deadline: game.worldMin + 480, destBuildingId: home.id });
  }

  function startMoveOut(c) {
    if (!c.resident || c.currentVehicleId || c.removed) return;
    const home = buildingById(c.homeId);
    const gate = chooseOpenGate();
    if (!home || !gate || gate.entrance == null) return;
    c.state = 'กำลังย้ายออก';
    c.movingOut = true;
    createTrip({ citizen: c, fromIdx: home.entrance, toIdx: gate.entrance, type: 'MoveOutTrip', deadline: game.worldMin + 1440, gateId: gate.id });
  }

  function createTrip(opts) {
    const from = opts.fromIdx, to = opts.toIdx;
    if (from == null || to == null || !road[from] || !road[to]) return false;
    if (!canEnterCell(from, -1)) return false;
    const path = opts.prePath || findPath(from, to, false);
    if (!path.length) return false;
    const id = nextVehicleId++;
    occupyCell(from, id);
    const v = {
      id,
      citizenId: opts.citizen ? opts.citizen.id : null,
      type: opts.type,
      path,
      pathPos: 0,
      currentIdx: from,
      nextIdx: null,
      t: 0,
      deadline: opts.deadline,
      destBuildingId: opts.destBuildingId || null,
      gateId: opts.gateId || null,
      targetGateId: opts.targetGateId || null,
      reservedService: !!opts.reservedService,
      activityEnd: opts.activityEnd || null,
      waitingGameMin: 0,
      rerouted: false,
      bornAt: game.worldMin,
      color: vehicleColor(opts.type)
    };
    vehicles.push(v);
    if (opts.citizen) {
      opts.citizen.currentVehicleId = id;
      opts.citizen.lastTrip = opts.type;
    }
    return true;
  }

  function vehicleColor(type) {
    if (type === 'WorkTrip') return '#4aa3ff';
    if (type === 'ReturnHomeTrip') return '#ffffff';
    if (type === 'LeisureTrip') return '#ff77dc';
    if (type === 'MoveInTrip') return '#8cff90';
    if (type === 'MoveOutTrip') return '#ff6b6b';
    return '#ffd166';
  }

  class MinHeap {
    constructor() { this.a = []; }
    push(item, p) { const a = this.a; a.push({ item, p }); let i = a.length - 1; while (i > 0) { const m = (i - 1) >> 1; if (a[m].p <= p) break; [a[i], a[m]] = [a[m], a[i]]; i = m; } }
    pop() { const a = this.a; if (!a.length) return null; const root = a[0]; const last = a.pop(); if (a.length) { a[0] = last; let i = 0; while (true) { let l = i * 2 + 1, r = l + 1, s = i; if (l < a.length && a[l].p < a[s].p) s = l; if (r < a.length && a[r].p < a[s].p) s = r; if (s === i) break; [a[i], a[s]] = [a[s], a[i]]; i = s; } } return root.item; }
    get length() { return this.a.length; }
  }

  const searchMark = new Int32Array(MAP_SIZE);
  const closedMark = new Int32Array(MAP_SIZE);
  const cameFrom = new Int32Array(MAP_SIZE);
  const gScore = new Float32Array(MAP_SIZE);
  let searchToken = 1;

  function findPath(start, goal, quiet = false) {
    if (start === goal) return [start];
    if (!road[start] || !road[goal]) return [];
    const cacheKey = `${roadVersion}:${start}:${goal}`;
    const cached = pathCache.get(cacheKey);
    if (cached) return cached;

    searchToken++;
    if (searchToken > 2000000000) { searchMark.fill(0); closedMark.fill(0); searchToken = 1; }
    const heap = new MinHeap();
    searchMark[start] = searchToken;
    gScore[start] = 0;
    cameFrom[start] = -1;
    heap.push(start, heuristic(start, goal));
    let found = false;
    let iter = 0;
    while (heap.length && iter++ < 32000) {
      const cur = heap.pop();
      if (closedMark[cur] === searchToken) continue;
      if (cur === goal) { found = true; break; }
      closedMark[cur] = searchToken;
      for (const ni of linkedNeighbors(cur)) {
        if (!road[ni]) continue;
        if (closedMark[ni] === searchToken) continue;
        const cx = cur % MAP_W, cy = Math.floor(cur / MAP_W);
        const nx = ni % MAP_W, ny = Math.floor(ni / MAP_W);
        const dx = nx - cx, dy = ny - cy;
        const step = (dx && dy) ? 1.414 : 1;
        const rd = roadDataById(road[ni]);
        const ratio = getRoadRatio(ni);
        const interPenalty = connCache[ni] >= 3 ? 0.35 : 0;
        const tentative = gScore[cur] + step * (5 / rd.speed) * (1 + Math.max(0, ratio - 0.55) * 1.5) + interPenalty;
        if (searchMark[ni] !== searchToken || tentative < gScore[ni]) {
          searchMark[ni] = searchToken;
          cameFrom[ni] = cur;
          gScore[ni] = tentative;
          heap.push(ni, tentative + heuristic(ni, goal));
        }
      }
    }
    if (!found) {
      if (!quiet) addAlert('หาเส้นทางไม่ได้', 'ถนนยังไม่เชื่อมต่อจากต้นทางถึงปลายทาง', 1);
      return [];
    }
    const path = [];
    let cur = goal;
    while (cur >= 0) {
      path.push(cur);
      if (cur === start) break;
      cur = cameFrom[cur];
    }
    path.reverse();
    if (path.length > 1 && pathCache.size < 4000) pathCache.set(cacheKey, path);
    return path;
  }

  function heuristic(a, b) {
    const ax = a % MAP_W, ay = Math.floor(a / MAP_W);
    const bx = b % MAP_W, by = Math.floor(b / MAP_W);
    return Math.max(Math.abs(ax - bx), Math.abs(ay - by)) * 0.8;
  }

  function updateVehicles(realDt, gameMinDt) {
    for (let i = vehicles.length - 1; i >= 0; i--) {
      const v = vehicles[i];
      if (v.deadline && game.worldMin > v.deadline && !v.rerouted && v.type !== 'ReturnHomeTrip' && v.type !== 'MoveOutTrip' && v.type !== 'PassThroughTrip') {
        timeoutVehicle(v);
      }
      moveVehicle(v, realDt, gameMinDt);
    }
  }

  function timeoutVehicle(v) {
    const c = v.citizenId ? citizens.find(x => x.id === v.citizenId) : null;
    if (v.reservedService && v.destBuildingId) {
      const b = buildingById(v.destBuildingId);
      if (b) { b.reservedService = Math.max(0, b.reservedService - 1); b.fails++; }
    }
    if (c && c.resident && !c.removed) {
      c.satisfaction -= 18;
      c.failCount++;
      addAlert('Trip ล้มเหลว', `Citizen ${c.id} ไปไม่ทันเวลา ต้อง Reroute กลับบ้าน`, 1);
      const home = buildingById(c.homeId);
      if (home) {
        clearNextCell(v);
        const path = findPath(v.currentIdx, home.entrance, true);
        if (path.length) {
          v.path = path;
          v.pathPos = 0;
          v.t = 0;
          v.nextIdx = null;
          v.type = 'ReturnHomeTrip';
          v.deadline = game.worldMin + 480;
          v.destBuildingId = home.id;
          v.reservedService = false;
          v.rerouted = true;
          v.color = vehicleColor('ReturnHomeTrip');
          c.state = 'กลับบ้านหลัง Trip Fail';
        }
      }
      if (c.failCount >= 3 && !c.movingOut) {
        c.movingOut = true;
        pushEvent(game.worldMin + 15, 'moveOut', { citizenId: c.id });
      }
    }
  }

  function moveVehicle(v, realDt, gameMinDt) {
    const rd = roadDataById(road[v.currentIdx]);
    if (rd) flowLoad[v.currentIdx] += realDt * 5;
    if (v.pathPos >= v.path.length - 1) { arriveVehicle(v); return; }

    if (v.nextIdx == null) {
      const ni = v.path[v.pathPos + 1];
      if (!road[ni]) { timeoutVehicle(v); return; }
      if (!canEnterCell(ni, v.id)) {
        waitLoad[v.currentIdx] += realDt * 4;
        v.waitingGameMin += gameMinDt;
        return;
      }
      if (isRedForMove(v.currentIdx, ni)) {
        waitLoad[v.currentIdx] += realDt * 5;
        v.waitingGameMin += gameMinDt;
        return;
      }
      occupyCell(ni, v.id);
      v.nextIdx = ni;
      v.t = 0;
    }

    const nr = roadDataById(road[v.nextIdx]) || rd || DATA.roads.small;
    const ratio = getRoadRatio(v.nextIdx);
    const slow = ratio <= 0.6 ? 1 : ratio <= 1.2 ? 1 / (1 + (ratio - 0.6) * 1.2) : 0.35;
    const speed = nr.speed * game.speed * slow;
    v.t += realDt * speed;
    if (v.t >= 1) {
      releaseCell(v.currentIdx, v.id);
      v.currentIdx = v.nextIdx;
      v.pathPos++;
      v.nextIdx = null;
      v.t = 0;
      if (v.waitingGameMin > 30 && !v.rerouteCooldown) {
        tryReroute(v);
        v.rerouteCooldown = game.worldMin + 10;
        v.waitingGameMin = 0;
      }
    }
  }

  function isRedForMove(from, to) {
    if (!isJunctionCell(to)) return false;
    return moveAxis(from, to) !== signalPhase(to);
  }

  function tryReroute(v) {
    if (v.rerouteCooldown && game.worldMin < v.rerouteCooldown) return;
    const dest = v.path[v.path.length - 1];
    clearNextCell(v);
    const path = findPath(v.currentIdx, dest, true);
    if (path.length && path.length < Math.max(2, v.path.length - v.pathPos + 6)) {
      v.path = path;
      v.pathPos = 0;
      v.t = 0;
      v.nextIdx = null;
      v.rerouted = true;
    }
  }

  function arriveVehicle(v) {
    clearNextCell(v);
    releaseCell(v.currentIdx, v.id);
    const vi = vehicles.indexOf(v);
    if (vi >= 0) vehicles.splice(vi, 1);
    if (v.type === 'PassThroughTrip') return;
    const c = v.citizenId ? citizens.find(x => x.id === v.citizenId) : null;
    if (!c || c.removed) return;
    c.currentVehicleId = null;
    const b = v.destBuildingId ? buildingById(v.destBuildingId) : null;
    if (v.type === 'MoveInTrip') {
      if (b) {
        b.reservedResidents = Math.max(0, b.reservedResidents - 1);
        b.residents++;
        b.citizenIds.push(c.id);
        b.arrivals++;
        c.resident = true;
        c.location = `building:${b.id}`;
        c.state = 'อยู่บ้าน';
        assignJobFor(c);
        scheduleCitizenDay(c, absDay());
      }
    } else if (v.type === 'WorkTrip') {
      if (b) b.arrivals++;
      c.location = `building:${b.id}`;
      c.state = 'อยู่ที่ทำงาน';
      c.satisfaction = Math.min(100, c.satisfaction + 2);
    } else if (v.type === 'LeisureTrip') {
      if (b) {
        b.reservedService = Math.max(0, b.reservedService - 1);
        b.visitors++;
        b.arrivals++;
        c.location = `building:${b.id}`;
        c.state = `อยู่${kindName(b.kind)}`;
        c.satisfaction = Math.min(100, c.satisfaction + 7);
        pushEvent(v.activityEnd || game.worldMin + 120, 'returnHome', { citizenId: c.id, reason: 'จบกิจกรรม' });
      }
    } else if (v.type === 'ReturnHomeTrip') {
      if (b) b.arrivals++;
      c.location = `building:${c.homeId}`;
      c.state = 'อยู่บ้าน';
      c.satisfaction = Math.min(100, c.satisfaction + 1);
    } else if (v.type === 'MoveOutTrip') {
      const home = buildingById(c.homeId);
      if (home) {
        home.residents = Math.max(0, home.residents - 1);
        home.citizenIds = home.citizenIds.filter(id => id !== c.id);
      }
      const work = buildingById(c.workId);
      if (work) {
        work.employees = Math.max(0, work.employees - 1);
        work.workerIds = work.workerIds.filter(id => id !== c.id);
      }
      c.removed = true;
      c.resident = false;
      const g = gates.find(x => x.id === v.gateId);
      if (g) g.outToday++;
    }
  }

  function decayTraffic(realDt) {
    const decay = Math.pow(0.92, realDt * 4);
    for (let i = 0; i < MAP_SIZE; i++) {
      if (flowLoad[i] > 0.01) flowLoad[i] *= decay;
      else flowLoad[i] = 0;
      if (waitLoad[i] > 0.01) waitLoad[i] *= decay;
      else waitLoad[i] = 0;
    }
  }

  function update(realDt) {
    if (game.speed === 0) return;
    const gameMinDt = realDt * 2 * game.speed;
    game.worldMin += gameMinDt;
    processEvents();
    immigrationManager(gameMinDt);
    passThroughManager(gameMinDt);
    updateVehicles(realDt, gameMinDt);
    decayTraffic(realDt);
    if (game.skipMode && minuteOfDay() >= 6 * 60 && minuteOfDay() < 6 * 60 + 5) {
      game.speed = 1; game.skipMode = false; updateSpeedButtons();
      addAlert('ข้ามวันเสร็จ', 'ระบบประมวลผลจนถึง 06:00 แล้ว', 1, 'good');
    }
  }

  function computeStats() {
    const population = citizens.filter(c => c.resident && !c.removed).length;
    const movingIn = citizens.filter(c => !c.resident && !c.removed && c.state === 'กำลังย้ายเข้า').length;
    const unemployed = citizens.filter(c => c.resident && !c.removed && c.profile.workDays.length && !c.workId).length;
    const jobCap = buildings.reduce((s,b) => s + buildingType(b).jobs, 0);
    const jobsUsed = buildings.reduce((s,b) => s + b.employees, 0);
    const jobVac = Math.max(0, jobCap - jobsUsed);
    const avgSat = population ? citizens.filter(c => c.resident && !c.removed).reduce((s,c)=>s+c.satisfaction,0) / population : 100;
    let ratioSum = 0, rc = 0;
    for (let i = 0; i < MAP_SIZE; i++) if (road[i]) { ratioSum += Math.min(2, getRoadRatio(i)); rc++; }
    const avgRatio = rc ? ratioSum / rc : 0;
    const trafficFlow = clamp(100 - avgRatio * 65, 0, 100);
    const residentTax = citizens.filter(c => c.resident && !c.removed && !c.movingOut).reduce((s, c) => s + c.profile.tax, 0);
    const businessTax = buildings.reduce((s, b) => s + b.employees * 50, 0);
    const maintenance = computeRoadMaintenance() + buildings.reduce((s,b)=>s+buildingType(b).maintenance,0);
    const activeTrips = vehicles.length;
    return { population, movingIn, unemployed, jobVac, avgSat, trafficFlow, residentTax, businessTax, maintenance, activeTrips };
  }

  function renderStats() {
    const s = computeStats();
    game.lastStats = s;
    const net = s.residentTax + s.businessTax - s.maintenance;
    const rows = [
      { icon:'🕒', label:'เวลา', value:timeText(), cls:'clock' },
      { icon:'💰', label:'เงิน', value:formatMoney(game.money), cls:game.money < 0 ? 'bad' : 'good' },
      { icon:'📈', label:'สุทธิ/วัน', value:`${net >= 0 ? '+' : ''}${formatMoney(net)}`, cls:net >= 0 ? 'good' : 'bad' },
      { icon:'👥', label:'ประชากร', value:formatMoney(s.population), cls:s.population ? 'good' : 'warn' },
      { icon:'😊', label:'ความสุข', value:`${Math.round(s.avgSat)}%`, cls:kpiState(s.avgSat, 75, 45) },
      { icon:'🚗', label:'Traffic Flow', value:`${Math.round(s.trafficFlow)}%`, cls:kpiState(s.trafficFlow, 70, 40) },
    ];
    statsEl.innerHTML = rows.map(r => `<div class="stat ${r.cls || ''}"><span class="label">${r.icon} ${r.label}</span><b>${r.value}</b></div>`).join('');
  }

  function renderAlerts() {
    const recent = alerts.slice(0, 5);
    alertsEl.innerHTML = recent.length ? recent.map(a => `
      <div class="alert ${a.kind === 'good' ? 'good' : ''}">
        <b>${a.kind === 'good' ? '✅' : '⚠️'} ${escapeHtml(a.title)} ${a.count > 1 ? `×${a.count}` : ''}</b>
        ${escapeHtml(a.detail)}
      </div>`).join('') : '<div class="card muted">✅ เมืองยังไม่มีปัญหาหลัก ลองเปิด Heatmap เมื่อรถเริ่มเยอะ</div>';
  }

  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }

  function draw() {
    const w = window.innerWidth, h = window.innerHeight;
    ctx.clearRect(0, 0, w, h);
    drawTerrain(w, h);
    const view = visibleGridBounds(w, h);
    drawGrid(view);
    drawRoads(view);
    drawBuildings(view);
    drawGates();
    drawVehicles();
    drawPreview();
    drawHoverInfo();
  }

  function visibleGridBounds(w, h) {
    const a = screenToGrid(-80, -80);
    const b = screenToGrid(w + 80, h + 80);
    return { minX: clamp(a.x, 0, MAP_W - 1), minY: clamp(a.y, 0, MAP_H - 1), maxX: clamp(b.x, 0, MAP_W - 1), maxY: clamp(b.y, 0, MAP_H - 1) };
  }

  function drawTerrain(w, h) {
    const city = DATA.cities[game.cityKey];
    const g = ctx.createLinearGradient(0, 0, w, h);
    if (city.terrain === 'island') {
      g.addColorStop(0, '#7ec8d7');
      g.addColorStop(.30, '#9bd2c3');
      g.addColorStop(.46, '#d8c982');
      g.addColorStop(.54, '#8fc476');
      g.addColorStop(1, '#6faa63');
    } else if (city.terrain === 'river') {
      g.addColorStop(0, '#9acb88');
      g.addColorStop(.46, '#86bd76');
      g.addColorStop(.5, '#4aa6c8');
      g.addColorStop(.55, '#83b973');
      g.addColorStop(1, '#77ad67');
    } else if (city.terrain === 'mountain') {
      g.addColorStop(0, '#7fac70');
      g.addColorStop(.26, '#a4a571');
      g.addColorStop(.34, '#7aa268');
      g.addColorStop(1, '#79b16a');
    } else {
      g.addColorStop(0, '#a3c879');
      g.addColorStop(.52, '#95bf6d');
      g.addColorStop(1, '#85ae62');
    }
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, w, h);

    // Subtle map texture: softer than the old debug-like terrain.
    ctx.save();
    ctx.globalAlpha = .10;
    ctx.fillStyle = '#ffffff';
    for (let i = 0; i < 34; i++) {
      const x = (i * 193 + 41) % Math.max(1, w);
      const y = (i * 137 + 79) % Math.max(1, h);
      const rw = 90 + (i * 31) % 180;
      const rh = 24 + (i * 17) % 78;
      ctx.beginPath();
      ctx.ellipse(x, y, rw, rh, (i % 7) * .35, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.restore();

    if (city.terrain === 'river') {
      ctx.save();
      ctx.lineCap = 'round';
      ctx.strokeStyle = 'rgba(24, 119, 151, .72)';
      ctx.lineWidth = Math.max(70, h * .09);
      ctx.beginPath();
      ctx.moveTo(w * .44, -40);
      ctx.bezierCurveTo(w * .55, h * .18, w * .34, h * .36, w * .48, h * .55);
      ctx.bezierCurveTo(w * .62, h * .73, w * .44, h * .9, w * .57, h + 50);
      ctx.stroke();
      ctx.strokeStyle = 'rgba(226, 248, 255, .40)';
      ctx.lineWidth = Math.max(13, h * .015);
      ctx.stroke();
      ctx.restore();
    }

    if (city.terrain === 'mountain') {
      ctx.save();
      ctx.globalAlpha = .25;
      ctx.fillStyle = '#405b3a';
      for (let i = 0; i < 5; i++) {
        ctx.beginPath();
        ctx.moveTo(-60, h * (.1 + i * .18));
        ctx.lineTo(w * (.16 + i * .02), h * (.03 + i * .18));
        ctx.lineTo(w * (.3 + i * .03), h * (.16 + i * .18));
        ctx.lineTo(-60, h * (.25 + i * .18));
        ctx.closePath();
        ctx.fill();
      }
      ctx.restore();
    }

    // Soft vignette keeps the play area readable under UI panels.
    const vignette = ctx.createRadialGradient(w/2, h/2, Math.min(w,h)*.2, w/2, h/2, Math.max(w,h)*.72);
    vignette.addColorStop(0, 'rgba(255,255,255,0)');
    vignette.addColorStop(1, 'rgba(15,23,42,.16)');
    ctx.fillStyle = vignette;
    ctx.fillRect(0,0,w,h);
  }

  function drawGrid(view) {
    if (!game.debug && game.zoom < 1.05) return;
    const zt = TILE * game.zoom;
    ctx.strokeStyle = game.debug ? 'rgba(15,23,42,.13)' : 'rgba(15,23,42,.045)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    for (let x = view.minX; x <= view.maxX; x++) {
      const sx = Math.floor(x * zt + game.pan.x) + .5;
      ctx.moveTo(sx, view.minY * zt + game.pan.y);
      ctx.lineTo(sx, (view.maxY + 1) * zt + game.pan.y);
    }
    for (let y = view.minY; y <= view.maxY; y++) {
      const sy = Math.floor(y * zt + game.pan.y) + .5;
      ctx.moveTo(view.minX * zt + game.pan.x, sy);
      ctx.lineTo((view.maxX + 1) * zt + game.pan.x, sy);
    }
    ctx.stroke();
  }

  function roadVisualWidth(rt, zt) {
    // Visual width now follows lane count clearly: 2 / 4 / 8 lanes.
    if (rt === 1) return clamp(zt * .54, 5, 18);
    if (rt === 2) return clamp(zt * .86, 7, 28);
    return clamp(zt * 1.22, 10, 40);
  }

  function roadBaseColor(rt) {
    if (rt === 1) return '#68737e';
    if (rt === 2) return '#5e6b76';
    return '#566472';
  }

  function roadShoulderColor(rt) {
    if (rt === 1) return '#3f4851';
    if (rt === 2) return '#3a444e';
    return '#34404b';
  }

  function roadPoint(x, y, zt) {
    return { sx: x * zt + game.pan.x + zt / 2, sy: y * zt + game.pan.y + zt / 2 };
  }

  function drawLaneMarkings(seg, p1, p2, width, zt) {
    const lanes = roadDataById(seg.rt).lanes;
    if (lanes <= 1) return;
    const dx = p2.sx - p1.sx, dy = p2.sy - p1.sy;
    const len = Math.hypot(dx, dy) || 1;
    const nx = -dy / len, ny = dx / len;
    ctx.save();
    ctx.lineCap = 'round';
    for (let k = 1; k < lanes; k++) {
      const offset = (k / lanes - 0.5) * width * 0.82;
      const isCenter = lanes % 2 === 0 && k === lanes / 2;
      ctx.strokeStyle = isCenter ? 'rgba(255, 226, 122, .78)' : 'rgba(240, 245, 250, .58)';
      ctx.lineWidth = isCenter ? clamp(zt * .04, 1, 2.3) : clamp(zt * .026, .8, 1.6);
      if (!isCenter || lanes >= 4) ctx.setLineDash([clamp(zt * .16, 3, 6), clamp(zt * .18, 3, 7)]);
      else ctx.setLineDash([clamp(zt * .28, 4, 10), clamp(zt * .24, 4, 9)]);
      ctx.beginPath();
      ctx.moveTo(p1.sx + nx * offset, p1.sy + ny * offset);
      ctx.lineTo(p2.sx + nx * offset, p2.sy + ny * offset);
      ctx.stroke();
    }
    ctx.restore();
  }

  function visibleRoadSegments(view) {
    const segs = [];
    const dots = [];
    const seen = new Set();
    for (let y = view.minY; y <= view.maxY; y++) for (let x = view.minX; x <= view.maxX; x++) {
      const i = idx(x,y);
      const rt = road[i];
      if (!rt) continue;
      const links = linkedNeighbors(i);
      if (!links.length) dots.push({ x, y, i, rt });
      for (const ni of links) {
        if (!road[ni]) continue;
        const key = i < ni ? `${i}:${ni}` : `${ni}:${i}`;
        if (seen.has(key)) continue;
        seen.add(key);
        const n = xy(ni);
        // Draw only visible-ish segments, but keep edges crossing viewport borders.
        if (n.x < view.minX - 1 || n.x > view.maxX + 1 || n.y < view.minY - 1 || n.y > view.maxY + 1) continue;
        segs.push({ x1:x, y1:y, x2:n.x, y2:n.y, i, j:ni, rt:Math.max(rt, road[ni]) });
      }
    }
    return { segs, dots };
  }


  function drawRoads(view) {
    const zt = TILE * game.zoom;
    const { segs, dots } = visibleRoadSegments(view);

    function drawSegLayer(layer) {
      ctx.save();
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      for (const s of segs) {
        const p1 = roadPoint(s.x1, s.y1, zt);
        const p2 = roadPoint(s.x2, s.y2, zt);
        const width = roadVisualWidth(s.rt, zt);
        if (layer === 'shadow') {
          ctx.strokeStyle = 'rgba(3, 6, 9, .44)';
          ctx.lineWidth = width + Math.max(3, zt * .16);
        } else if (layer === 'shoulder') {
          ctx.strokeStyle = roadShoulderColor(s.rt);
          ctx.lineWidth = width + Math.max(2, zt * .08);
        } else if (layer === 'base') {
          ctx.strokeStyle = roadBaseColor(s.rt);
          ctx.lineWidth = width;
        } else if (layer === 'heat') {
          if (!game.heatmap) continue;
          const ratio = (getRoadRatio(s.i) + getRoadRatio(s.j)) / 2;
          ctx.strokeStyle = trafficColor(ratio);
          ctx.globalAlpha = .82;
          ctx.lineWidth = width * .62;
        } else if (layer === 'lane') {
          if (game.heatmap || game.zoom <= .46) continue;
          drawLaneMarkings(s, p1, p2, width, zt);
          continue;
        }
        ctx.beginPath();
        ctx.moveTo(p1.sx, p1.sy);
        ctx.lineTo(p2.sx, p2.sy);
        ctx.stroke();
      }
      for (const d of dots) {
        const p = roadPoint(d.x, d.y, zt);
        const width = roadVisualWidth(d.rt, zt);
        if (layer === 'shadow') ctx.fillStyle = 'rgba(3, 6, 9, .44)';
        else if (layer === 'shoulder') ctx.fillStyle = roadShoulderColor(d.rt);
        else if (layer === 'base') ctx.fillStyle = roadBaseColor(d.rt);
        else if (layer === 'heat') { if (!game.heatmap) continue; ctx.fillStyle = trafficColor(getRoadRatio(d.i)); ctx.globalAlpha = .82; }
        else continue;
        ctx.beginPath();
        ctx.arc(p.sx, p.sy, width * (layer === 'shadow' ? .64 : layer === 'shoulder' ? .57 : .5), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }

    drawSegLayer('shadow');
    drawSegLayer('shoulder');
    drawSegLayer('base');
    drawSegLayer('heat');

    // Smooth intersection pads cover segment seams and make junctions look intentional.
    for (let y = view.minY; y <= view.maxY; y++) for (let x = view.minX; x <= view.maxX; x++) {
      const i = idx(x,y);
      if (!road[i] || connCache[i] < 3) continue;
      const rt = road[i];
      const p = roadPoint(x, y, zt);
      const width = roadVisualWidth(rt, zt);
      ctx.save();
      ctx.fillStyle = 'rgba(3, 6, 9, .38)';
      ctx.beginPath(); ctx.arc(p.sx, p.sy, width * .72, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = roadShoulderColor(rt);
      ctx.beginPath(); ctx.arc(p.sx, p.sy, width * .63, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = roadBaseColor(rt);
      ctx.beginPath(); ctx.arc(p.sx, p.sy, width * .55, 0, Math.PI*2); ctx.fill();
      if (game.heatmap) {
        ctx.save();
        ctx.globalAlpha = .82;
        ctx.fillStyle = trafficColor(getRoadRatio(i));
        ctx.beginPath(); ctx.arc(p.sx, p.sy, width * .36, 0, Math.PI*2); ctx.fill();
        ctx.restore();
      }
      if (!game.heatmap && game.zoom > .55) {
        ctx.strokeStyle = 'rgba(245, 246, 235, .42)';
        ctx.lineWidth = clamp(zt * .025, 1, 2);
        ctx.beginPath();
        ctx.moveTo(p.sx - width * .36, p.sy); ctx.lineTo(p.sx + width * .36, p.sy);
        ctx.moveTo(p.sx, p.sy - width * .36); ctx.lineTo(p.sx, p.sy + width * .36);
        ctx.stroke();
      }
      if (!game.heatmap && game.zoom > .72) drawTrafficSignal(p.sx, p.sy, width, i);
      if (game.debug) {
        const red = Math.floor(game.worldMin / 8) % 2;
        ctx.fillStyle = red ? '#ff5252' : '#52ff82';
        roundRect(ctx, p.sx - width*.16, p.sy - width*.16, width*.32, width*.32, 3); ctx.fill();
      }
      ctx.restore();
    }

    drawSegLayer('lane');

    if (game.debug) {
      for (let y = view.minY; y <= view.maxY; y++) for (let x = view.minX; x <= view.maxX; x++) {
        const i = idx(x,y);
        if (!road[i]) continue;
        const p = roadPoint(x, y, zt);
        if (cellVehicleCount(i) > 0) {
          ctx.fillStyle = 'rgba(255,255,255,.38)';
          ctx.beginPath(); ctx.arc(p.sx, p.sy, clamp(zt*.16, 2, 6), 0, Math.PI*2); ctx.fill();
        }
        if (waitLoad[i] > 0.1) {
          ctx.fillStyle = 'rgba(255,0,0,.26)';
          ctx.fillRect(x*zt+game.pan.x, y*zt+game.pan.y, zt, zt);
        }
      }
    }
  }

  function isJunctionCell(i) {
    return road[i] && connCache[i] >= 3;
  }
  function signalPhase(i) {
    // Each junction has a deterministic offset so every red light does not switch at the exact same moment.
    const offset = (i * 7) % 11;
    return Math.floor((game.worldMin + offset) / 8) % 2; // 0 = east/west green, 1 = north/south green
  }
  function moveAxis(from, to) {
    const fx = from % MAP_W, fy = Math.floor(from / MAP_W);
    const tx = to % MAP_W, ty = Math.floor(to / MAP_W);
    const dx = tx - fx, dy = ty - fy;
    if (Math.abs(dx) > Math.abs(dy)) return 0; // east/west
    if (Math.abs(dy) > Math.abs(dx)) return 1; // north/south
    return (dx * dy >= 0) ? 0 : 1; // 45° roads split into two compatible signal groups
  }
  function drawTrafficSignal(x, y, w, cellIdx) {
    const phase = signalPhase(cellIdx);
    const r = clamp(w * .075, 1.5, 3.4);
    const off = w * .54;
    const lights = [
      { x:-off, y:0, axis:0 }, { x:off, y:0, axis:0 },
      { x:0, y:-off, axis:1 }, { x:0, y:off, axis:1 }
    ];
    ctx.save();
    ctx.strokeStyle = 'rgba(255,255,255,.36)';
    ctx.lineWidth = clamp(w * .035, 1, 2);
    ctx.beginPath();
    ctx.moveTo(x - off * .58, y); ctx.lineTo(x - off * .25, y);
    ctx.moveTo(x + off * .25, y); ctx.lineTo(x + off * .58, y);
    ctx.moveTo(x, y - off * .58); ctx.lineTo(x, y - off * .25);
    ctx.moveTo(x, y + off * .25); ctx.lineTo(x, y + off * .58);
    ctx.stroke();
    for (const l of lights) {
      ctx.fillStyle = 'rgba(8,10,12,.78)';
      ctx.beginPath(); ctx.arc(x + l.x, y + l.y, r * 1.7, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = l.axis === phase ? '#50ff82' : '#ff4545';
      ctx.beginPath(); ctx.arc(x + l.x, y + l.y, r, 0, Math.PI*2); ctx.fill();
    }
    ctx.restore();
  }

  function roundRect(ctx, x, y, w, h, r) {
    r = Math.max(0, Math.min(r, Math.abs(w) / 2, Math.abs(h) / 2));
    ctx.beginPath();
    ctx.moveTo(x+r,y); ctx.arcTo(x+w,y,x+w,y+h,r); ctx.arcTo(x+w,y+h,x,y+h,r); ctx.arcTo(x,y+h,x,y,r); ctx.arcTo(x,y,x+w,y,r);
    ctx.closePath();
  }

  function drawBuildings(view) {
    const zt = TILE * game.zoom;
    for (const b of buildings) {
      if (b.x + b.w < view.minX || b.y + b.h < view.minY || b.x > view.maxX || b.y > view.maxY) continue;
      const t = buildingType(b);
      const sx = b.x * zt + game.pan.x, sy = b.y * zt + game.pan.y;
      const bw = b.w * zt, bh = b.h * zt;
      const inset = Math.max(2, zt * .08);
      ctx.save();
      ctx.shadowColor = 'rgba(0,0,0,.34)';
      ctx.shadowBlur = clamp(zt * .35, 3, 12);
      ctx.shadowOffsetY = clamp(zt * .12, 1, 5);
      const grad = ctx.createLinearGradient(sx, sy, sx, sy + bh);
      grad.addColorStop(0, lightenColor(t.color, .18));
      grad.addColorStop(1, darkenColor(t.color, .13));
      ctx.fillStyle = grad;
      roundRect(ctx, sx + inset, sy + inset, bw - inset*2, bh - inset*2, Math.max(4, zt * .18));
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.strokeStyle = 'rgba(255,255,255,.20)'; ctx.lineWidth = 1;
      ctx.stroke();
      ctx.strokeStyle = 'rgba(0,0,0,.28)'; ctx.lineWidth = 2;
      ctx.stroke();

      // Roof/highlight plate.
      ctx.fillStyle = 'rgba(255,255,255,.16)';
      roundRect(ctx, sx + inset*2, sy + inset*2, bw - inset*4, Math.max(4, bh * .18), Math.max(3, zt*.11));
      ctx.fill();

      drawBuildingIcon(t, sx + bw/2, sy + bh/2, Math.min(bw, bh), zt);

      const e = xy(b.entrance);
      const ex = e.x * zt + game.pan.x + zt/2, ey = e.y * zt + game.pan.y + zt/2;
      ctx.strokeStyle = 'rgba(255,255,255,.75)'; ctx.lineWidth = clamp(zt*.08, 1.5, 4); ctx.lineCap = 'round';
      ctx.beginPath(); ctx.moveTo(sx + bw/2, sy + bh/2); ctx.lineTo(ex, ey); ctx.stroke();
      ctx.fillStyle = '#fff'; ctx.strokeStyle = 'rgba(0,0,0,.45)'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.arc(ex, ey, Math.max(2.2, zt*.15), 0, Math.PI*2); ctx.fill(); ctx.stroke();

      if (game.zoom > .54) {
        ctx.fillStyle = 'rgba(5,10,15,.78)';
        ctx.font = `700 ${Math.max(9, zt*.34)}px sans-serif`;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        const label = t.name.replace('เล็ก','').replace('ใหญ่','');
        ctx.fillText(label, sx + bw/2, sy + Math.min(bh - 9, 14));
        ctx.textAlign = 'start'; ctx.textBaseline = 'alphabetic';
      }
      if (game.debug) {
        ctx.fillStyle = 'rgba(0,0,0,.72)';
        ctx.font = '10px sans-serif';
        ctx.fillText(`#${b.id} R:${b.residents}/${t.residents||0} J:${b.employees}/${t.jobs}`, sx+4, sy+bh-5);
      }
      ctx.restore();
    }
  }

  function drawBuildingIcon(t, cx, cy, size, zt) {
    if (game.zoom < .42) return;
    ctx.save();
    ctx.strokeStyle = 'rgba(0,0,0,.42)';
    ctx.fillStyle = 'rgba(255,255,255,.78)';
    ctx.lineWidth = clamp(zt*.045, 1, 2.5);
    const s = clamp(size * .22, 5, 20);
    if (t.kind === 'home') {
      ctx.beginPath(); ctx.moveTo(cx-s, cy); ctx.lineTo(cx, cy-s*.9); ctx.lineTo(cx+s, cy); ctx.closePath(); ctx.fill(); ctx.stroke();
      roundRect(ctx, cx-s*.72, cy, s*1.44, s*.95, 2); ctx.fill(); ctx.stroke();
    } else if (t.kind === 'park') {
      ctx.fillStyle = 'rgba(255,255,255,.5)';
      ctx.beginPath(); ctx.arc(cx-s*.35, cy, s*.55, 0, Math.PI*2); ctx.arc(cx+s*.35, cy, s*.55, 0, Math.PI*2); ctx.fill();
      ctx.stroke();
    } else if (t.kind === 'office' || t.kind === 'factory') {
      roundRect(ctx, cx-s*.72, cy-s*.8, s*1.44, s*1.6, 2); ctx.fill(); ctx.stroke();
      ctx.fillStyle = 'rgba(0,0,0,.35)';
      for (let ix=-1; ix<=1; ix++) for (let iy=-1; iy<=1; iy++) ctx.fillRect(cx+ix*s*.35-1, cy+iy*s*.38-1, 2, 2);
    } else if (t.kind === 'restaurant') {
      ctx.beginPath(); ctx.arc(cx, cy, s*.68, 0, Math.PI*2); ctx.fill(); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(cx-s*.9, cy-s*.8); ctx.lineTo(cx-s*.9, cy+s*.8); ctx.moveTo(cx+s*.8, cy-s*.8); ctx.lineTo(cx+s*.8, cy+s*.8); ctx.stroke();
    } else if (t.kind === 'pub') {
      ctx.beginPath(); ctx.moveTo(cx-s*.7, cy-s*.75); ctx.lineTo(cx+s*.7, cy-s*.75); ctx.lineTo(cx+s*.25, cy+s*.7); ctx.lineTo(cx-s*.25, cy+s*.7); ctx.closePath(); ctx.fill(); ctx.stroke();
    } else {
      roundRect(ctx, cx-s*.8, cy-s*.55, s*1.6, s*1.1, 3); ctx.fill(); ctx.stroke();
    }
    ctx.restore();
  }

  function lightenColor(hex, amt) { return mixColor(hex, '#ffffff', amt); }
  function darkenColor(hex, amt) { return mixColor(hex, '#000000', amt); }
  function mixColor(hex, to, amt) {
    const a = parseColor(hex), b = parseColor(to);
    const r = Math.round(a.r + (b.r-a.r)*amt), g = Math.round(a.g + (b.g-a.g)*amt), bl = Math.round(a.b + (b.b-a.b)*amt);
    return `rgb(${r},${g},${bl})`;
  }
  function parseColor(hex) {
    const h = String(hex).replace('#','');
    return { r:parseInt(h.slice(0,2),16)||0, g:parseInt(h.slice(2,4),16)||0, b:parseInt(h.slice(4,6),16)||0 };
  }

  function drawGates() {
    const zt = TILE * game.zoom;
    for (const g of gates) {
      const sx = g.x * zt + game.pan.x + zt/2;
      const sy = g.y * zt + game.pan.y + zt/2;
      ctx.save();
      ctx.shadowColor = 'rgba(0,0,0,.45)'; ctx.shadowBlur = 12; ctx.shadowOffsetY = 4;
      const r = Math.max(10, zt*.72);
      const grd = ctx.createRadialGradient(sx-r*.3, sy-r*.35, r*.1, sx, sy, r);
      grd.addColorStop(0, '#fff0aa');
      grd.addColorStop(1, g.entrance != null ? '#ffd166' : '#ff6b6b');
      ctx.fillStyle = grd;
      ctx.strokeStyle = 'rgba(0,0,0,.65)'; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(sx, sy, r, 0, Math.PI*2); ctx.fill(); ctx.stroke();
      ctx.shadowBlur = 0;
      ctx.fillStyle = '#1b1510'; ctx.font = `900 ${Math.max(11, zt*.5)}px sans-serif`; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText('G', sx, sy+1);
      ctx.strokeStyle = 'rgba(255,255,255,.8)'; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(sx, sy, r*.72, 0, Math.PI*2); ctx.stroke();
      if (game.zoom > .52) {
        const label = g.name;
        ctx.font = '700 12px sans-serif';
        const tw = ctx.measureText(label).width + 16;
        ctx.fillStyle = 'rgba(9,14,20,.76)';
        roundRect(ctx, sx + r + 6, sy - 18, tw, 26, 9); ctx.fill();
        ctx.fillStyle = 'rgba(255,255,255,.95)'; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic'; ctx.fillText(label, sx + r + 14, sy - 1);
      }
      ctx.restore();
    }
    ctx.textAlign = 'start'; ctx.textBaseline = 'alphabetic';
  }

  function drawVehicles() {
    const zt = TILE * game.zoom;
    for (const v of vehicles) {
      let a = xy(v.currentIdx), px = a.x, py = a.y;
      if (v.nextIdx != null) {
        const b = xy(v.nextIdx);
        px = a.x + (b.x - a.x) * v.t;
        py = a.y + (b.y - a.y) * v.t;
      }
      let sx = px * zt + game.pan.x + zt/2;
      let sy = py * zt + game.pan.y + zt/2;
      const angle = vehicleAngle(v);
      const laneCell = v.nextIdx != null && v.t > .45 ? v.nextIdx : v.currentIdx;
      const lanes = Math.max(1, laneCapacityAt(laneCell));
      const laneIndex = vehicleLaneIndex(v, laneCell);
      const laneOffset = ((laneIndex + 0.5) / lanes - 0.5) * roadVisualWidth(road[laneCell] || road[v.currentIdx] || 1, zt) * .70;
      sx += -Math.sin(angle) * laneOffset;
      sy += Math.cos(angle) * laneOffset;
      if (sx < -30 || sy < -30 || sx > window.innerWidth + 30 || sy > window.innerHeight + 30) continue;
      drawCar(v, sx, sy, zt, angle);
      if (game.debug && v.path.length) drawVehiclePath(v, zt);
    }
  }

  function vehicleAngle(v) {
    let from = v.currentIdx;
    let to = v.nextIdx;
    if (to == null && v.pathPos + 1 < v.path.length) to = v.path[v.pathPos + 1];
    if (to == null && v.pathPos > 0) { from = v.path[v.pathPos - 1]; to = v.currentIdx; }
    if (to == null) return 0;
    const a = xy(from), b = xy(to);
    return Math.atan2(b.y - a.y, b.x - a.x);
  }

  function drawCar(v, sx, sy, zt, angle = vehicleAngle(v)) {
    const isTruck = v.type === 'PassThroughTrip';
    const len = clamp(zt * (isTruck ? .78 : .58), 6, isTruck ? 18 : 14);
    const wid = clamp(zt * (isTruck ? .34 : .30), 3.8, isTruck ? 8.5 : 7.5);
    ctx.save();
    ctx.translate(sx, sy);
    ctx.rotate(angle);
    ctx.shadowColor = 'rgba(0,0,0,.45)';
    ctx.shadowBlur = 5;
    ctx.shadowOffsetY = 2;
    ctx.fillStyle = v.color;
    ctx.strokeStyle = 'rgba(0,0,0,.68)';
    ctx.lineWidth = 1;
    roundRect(ctx, -len/2, -wid/2, len, wid, Math.max(2, wid*.36));
    ctx.fill(); ctx.stroke();
    ctx.shadowBlur = 0;

    // Windows / cabin.
    ctx.fillStyle = isTruck ? 'rgba(230,245,255,.82)' : 'rgba(18,35,48,.58)';
    roundRect(ctx, -len*.12, -wid*.36, len*.28, wid*.72, Math.max(1.5, wid*.22)); ctx.fill();
    if (isTruck) {
      ctx.fillStyle = 'rgba(255,255,255,.26)';
      roundRect(ctx, -len*.46, -wid*.36, len*.26, wid*.72, 2); ctx.fill();
    } else {
      ctx.fillStyle = 'rgba(255,255,255,.22)';
      roundRect(ctx, -len*.42, -wid*.30, len*.24, wid*.60, 2); ctx.fill();
    }

    // Headlights and taillights.
    ctx.fillStyle = '#fff6b2';
    ctx.fillRect(len/2 - 1.6, -wid*.28, 2, Math.max(1.2, wid*.18));
    ctx.fillRect(len/2 - 1.6, wid*.12, 2, Math.max(1.2, wid*.18));
    ctx.fillStyle = '#ff3e3e';
    ctx.fillRect(-len/2 - .2, -wid*.25, 1.8, Math.max(1.1, wid*.18));
    ctx.fillRect(-len/2 - .2, wid*.10, 1.8, Math.max(1.1, wid*.18));

    // Wheels when zoomed in enough.
    if (zt > 10) {
      ctx.fillStyle = 'rgba(5,5,5,.78)';
      ctx.fillRect(-len*.32, -wid*.58, len*.18, wid*.2);
      ctx.fillRect(len*.15, -wid*.58, len*.18, wid*.2);
      ctx.fillRect(-len*.32, wid*.38, len*.18, wid*.2);
      ctx.fillRect(len*.15, wid*.38, len*.18, wid*.2);
    }
    ctx.restore();
  }

  function drawVehiclePath(v, zt) {
    ctx.save();
    ctx.strokeStyle = 'rgba(255,255,255,.22)'; ctx.lineWidth = 1; ctx.setLineDash([4,4]);
    ctx.beginPath();
    for (let i = v.pathPos; i < Math.min(v.path.length, v.pathPos + 22); i++) {
      const p = xy(v.path[i]); const sx = p.x*zt+game.pan.x+zt/2, sy=p.y*zt+game.pan.y+zt/2;
      if (i === v.pathPos) ctx.moveTo(sx, sy); else ctx.lineTo(sx, sy);
    }
    ctx.stroke();
    ctx.restore();
  }

  function drawPreview() {
    if (!game.hover) return;
    const zt = TILE * game.zoom;
    const tool = game.selectedTool;
    if (!tool) return;
    if (tool.type === 'road' || tool.type === 'demolishRoad') {
      const start = game.roadStart || game.hover;
      const cells = getLineCells(start.x, start.y, game.hover.x, game.hover.y);
      const valid = tool.type === 'demolishRoad' ? true : canAddRoadCells(cells).ok && canSpend(estimateRoadCost(cells, tool.key));
      ctx.fillStyle = valid ? 'rgba(251, 191, 36, .34)' : 'rgba(239, 68, 68, .34)';
      for (const i of cells) {
        const p = xy(i);
        ctx.fillRect(p.x*zt+game.pan.x+2, p.y*zt+game.pan.y+2, zt-4, zt-4);
      }
    } else if (tool.type === 'building') {
      const t = DATA.buildings[tool.key];
      const x = game.hover.x, y = game.hover.y;
      const check = canPlaceBuilding(tool.key, x, y, true);
      ctx.fillStyle = check.ok ? 'rgba(255, 209, 102, .42)' : 'rgba(255, 80, 80, .42)';
      ctx.fillRect(x*zt+game.pan.x, y*zt+game.pan.y, t.w*zt, t.h*zt);
      ctx.strokeStyle = check.ok ? '#ffd166' : '#ff5656'; ctx.lineWidth = 2; ctx.strokeRect(x*zt+game.pan.x, y*zt+game.pan.y, t.w*zt, t.h*zt);
    }
  }

  function drawHoverInfo() {
    if (!game.hover) return;
    const tool = game.selectedTool;
    if (!tool) return;
    const text = previewText(tool, game.hover.x, game.hover.y);
    if (!text) return;
    ctx.font = '13px sans-serif';
    const tw = ctx.measureText(text).width + 18;
    const x = game.lastMouse.x + 14, y = game.lastMouse.y + 18;
    ctx.fillStyle = 'rgba(10,16,22,.88)'; roundRect(ctx, x, y, tw, 34, 9); ctx.fill();
    ctx.fillStyle = '#fff'; ctx.fillText(text, x + 9, y + 22);
  }

  function previewText(tool, x, y) {
    if (tool.type === 'road') {
      const start = game.roadStart || {x,y};
      const cells = getLineCells(start.x, start.y, x, y);
      const cost = estimateRoadCost(cells, tool.key);
      const valid = canAddRoadCells(cells);
      return valid.ok ? `${DATA.roads[tool.key].name} ${cells.length} ช่อง | ${formatMoney(cost)} บาท` : valid.reason;
    }
    if (tool.type === 'building') {
      const t = DATA.buildings[tool.key];
      const check = canPlaceBuilding(tool.key, x, y, true);
      return check.ok ? `${t.name} ${t.w}x${t.h} | ${formatMoney(t.cost)} บาท` : check.reason;
    }
    if (tool.type === 'demolishRoad') return 'รื้อถนน: ลากเส้นบนถนนที่ต้องการรื้อ';
    return '';
  }

  function estimateRoadCost(cells, roadKey) {
    const rd = DATA.roads[roadKey];
    let cost = 0;
    for (const i of cells) {
      const old = roadDataById(road[i]);
      if (!old) cost += rd.cost;
      else if (old.id < rd.id) cost += Math.max(0, rd.cost - old.cost);
    }
    return cost;
  }

  function toolIcon(type, key) {
    if (type === 'hand') return '👆';
    if (type === 'demolishRoad') return '🧹';
    if (type === 'road') return key === 'large' ? '🛣️' : key === 'medium' ? '🚧' : '➖';
    const b = DATA.buildings[key];
    if (!b) return '⬚';
    if (b.kind === 'home') return '🏠';
    if (b.kind === 'office') return '🏢';
    if (b.kind === 'factory') return '🏭';
    if (b.kind === 'restaurant') return '🍜';
    if (b.kind === 'shop') return '🛒';
    if (b.kind === 'mall') return '🏬';
    if (b.kind === 'park') return '🌳';
    if (b.kind === 'pub') return '🎵';
    return '⬚';
  }

  function buildToolButtons() {
    const groups = [];
    groups.push({ filter:'manage', title:'จัดการ', items:[
      { type:'hand', key:'hand', name:'มือเปล่า', meta:'คลิก Inspect • คลิกขวา/ล้อกลางเพื่อลากแผนที่' },
      { type:'demolishRoad', key:'demolishRoad', name:'รื้อถนน', meta:'ค่ารื้อ 20% ของราคาถนนเดิม' }
    ] });
    groups.push({ filter:'road', title:'ถนน', items:Object.values(DATA.roads).map(r => ({ type:'road', key:r.key, name:r.name, meta:`${r.lanes} เลน • ${r.cost}/ช่อง • บำรุง ${r.maintenance}/วัน` })) });

    const filterByCat = { 'บ้าน':'home', 'งาน':'job', 'อาคาร':'service', 'พักผ่อน':'leisure', 'กลางคืน':'night' };
    const cats = {};
    for (const b of Object.values(DATA.buildings)) {
      cats[b.category] ??= [];
      const cap = b.residents ? `คนอยู่ ${b.residents}` : b.service ? `บริการ ${b.service}` : `งาน ${b.jobs}`;
      cats[b.category].push({ type:'building', key:b.key, name:b.name, meta:`${b.w}x${b.h} • ${formatMoney(b.cost)} • ${cap}` });
    }
    for (const [title, items] of Object.entries(cats)) groups.push({ filter:filterByCat[title] || 'service', title, items });

    const tabs = [
      ['all','ทั้งหมด'], ['road','ถนน'], ['home','บ้าน'], ['job','งาน'], ['service','ร้าน/ห้าง'], ['leisure','พักผ่อน'], ['night','กลางคืน'], ['manage','จัดการ']
    ];
    toolListEl.innerHTML = `
      <div class="tool-tabs">
        ${tabs.map(([key,label]) => `<button class="tool-tab ${key === activeToolFilter ? 'active' : ''}" data-filter="${key}">${label}</button>`).join('')}
      </div>
      ${groups.map(g => `
      <div class="tool-group" data-filter="${g.filter}">
        <h3>${g.title}</h3>
        <div class="tool-grid">
          ${g.items.map(item => `<button class="tool" data-type="${item.type}" data-key="${item.key}"><strong><span class="tool-icon">${toolIcon(item.type, item.key)}</span>${item.name}</strong><small>${item.meta}</small></button>`).join('')}
        </div>
      </div>`).join('')}`;

    toolListEl.addEventListener('click', (e) => {
      const tab = e.target.closest('.tool-tab');
      if (tab) {
        activeToolFilter = tab.dataset.filter;
        applyToolFilter();
        return;
      }
      const btn = e.target.closest('.tool');
      if (!btn) return;
      const type = btn.dataset.type, key = btn.dataset.key;
      if (type === 'hand') game.selectedTool = null;
      else game.selectedTool = { type, key };
      game.roadStart = null;
      updateToolButtons();
      showToolInfo();
    });
    applyToolFilter();
  }

  function applyToolFilter() {
    for (const tab of toolListEl.querySelectorAll('.tool-tab')) tab.classList.toggle('active', tab.dataset.filter === activeToolFilter);
    for (const group of toolListEl.querySelectorAll('.tool-group')) {
      group.classList.toggle('is-hidden', activeToolFilter !== 'all' && group.dataset.filter !== activeToolFilter);
    }
  }

  function updateToolButtons() {
    for (const btn of toolListEl.querySelectorAll('.tool')) {
      const type = btn.dataset.type, key = btn.dataset.key;
      const selected = (!game.selectedTool && type === 'hand') || (game.selectedTool && game.selectedTool.type === type && game.selectedTool.key === key);
      btn.classList.toggle('active', selected);
      let cost = 0;
      if (type === 'building') cost = DATA.buildings[key].cost;
      else if (type === 'road') cost = DATA.roads[key].cost;
      btn.classList.toggle('disabled', cost > 0 && !canSpend(cost));
    }
  }

  function toolMetric(label, value) { return `<div class="metric"><span>${label}</span><b>${value}</b></div>`; }
  function showToolInfo() {
    if (!game.selectedTool) {
      selectionEl.innerHTML = '<div class="inspector-title">👆 มือเปล่า</div><div class="muted">คลิกถนน อาคาร Gate หรือรถ เพื่อดูรายละเอียดจาก Simulation จริง</div>';
      return;
    }
    const tool = game.selectedTool;
    if (tool.type === 'road') {
      const r = DATA.roads[tool.key];
      selectionEl.innerHTML = `<div class="inspector-title">${toolIcon('road', r.key)} ${r.name}</div>
        <div class="muted">${r.desc}</div>
        <div class="metric-grid">
          ${toolMetric('ราคา/ช่อง', `${formatMoney(r.cost)} บาท`)}
          ${toolMetric('บำรุง/วัน', `${r.maintenance} บาท`)}
          ${toolMetric('เลน', `${r.lanes} เลน`)}
          ${toolMetric('Capacity', `${r.capacity} คัน/ช่อง`)}
        </div>
        <div class="muted" style="margin-top:8px">คลิกจุดเริ่ม แล้วคลิกจุดปลาย ระบบ Snap 90°/45° ให้อัตโนมัติ</div>`;
    } else if (tool.type === 'building') {
      const b = DATA.buildings[tool.key];
      selectionEl.innerHTML = `<div class="inspector-title">${toolIcon('building', b.key)} ${b.name}</div>
        <div class="muted">${b.desc}</div>
        <div class="metric-grid">
          ${toolMetric('ขนาด', `${b.w}x${b.h}`)}
          ${toolMetric('ราคา', `${formatMoney(b.cost)} บาท`)}
          ${toolMetric('บำรุง', `${formatMoney(b.maintenance)} /วัน`)}
          ${toolMetric('ความจุ', `อยู่ ${b.residents||0} • งาน ${b.jobs} • บริการ ${b.service}`)}
        </div>
        <div class="muted" style="margin-top:8px">ต้องวางติดถนนและไม่ทับสิ่งก่อสร้าง</div>`;
    } else if (tool.type === 'demolishRoad') {
      selectionEl.innerHTML = '<div class="inspector-title">🧹 รื้อถนน</div><div class="muted">ลากเส้นบนถนนที่ต้องการรื้อ ค่ารื้อถอน 20% ของราคาก่อสร้างเดิม</div>';
    }
  }

  function inspectAt(x, y) {
    if (!inBounds(x,y)) return;
    const vehicle = findVehicleNear(x, y);
    if (vehicle) { inspectVehicle(vehicle); return; }
    const gate = isGateCell(x, y);
    if (gate) { inspectGate(gate); return; }
    const bid = buildGrid[idx(x,y)];
    if (bid) { inspectBuilding(buildingById(bid)); return; }
    if (road[idx(x,y)]) { inspectRoad(x,y); return; }
    selectionEl.innerHTML = '<div class="inspector-title">พื้นที่ว่าง</div><div class="muted">เลือกเครื่องมือเพื่อสร้างถนนหรืออาคาร</div>';
  }

  function findVehicleNear(gx, gy) {
    for (const v of vehicles) {
      const p = xy(v.currentIdx);
      if (Math.abs(p.x - gx) <= 1 && Math.abs(p.y - gy) <= 1) return v;
    }
    return null;
  }
  function inspectVehicle(v) {
    const c = v.citizenId ? citizens.find(x => x.id === v.citizenId) : null;
    const dest = v.destBuildingId ? buildingById(v.destBuildingId) : null;
    selectionEl.innerHTML = `<div class="inspector-title">🚗 รถ #${v.id}</div>
      <div class="muted">${c ? `Citizen ${c.id} • นิสัย ${c.profile.trait}` : 'รถผ่านเมืองจาก Gate'}</div>
      <div class="metric-grid">
        ${toolMetric('Trip', v.type)}
        ${toolMetric('สถานะ', c ? c.state : 'ผ่านเมือง')}
        ${toolMetric('ปลายทาง', dest ? dest.name : v.targetGateId ? 'Gate ปลายทาง' : '-')}
        ${toolMetric('รอสะสม', `${Math.round(v.waitingGameMin)} นาทีเกม`)}
        ${toolMetric('ความสุข', c ? `${Math.round(c.satisfaction)}%` : '-')}
        ${toolMetric('Path เหลือ', `${Math.max(0, v.path.length - v.pathPos)} ช่อง`)}
      </div>`;
  }
  function inspectGate(g) {
    selectionEl.innerHTML = `<div class="inspector-title">🚪 ${g.name}</div>
      <div class="muted">${g.role}</div>
      <div class="metric-grid">
        ${toolMetric('สถานะ', g.entrance != null ? 'เชื่อมถนนแล้ว' : 'ยังไม่เชื่อม')}
        ${toolMetric('ย้ายเข้า/วันนี้', g.inToday)}
        ${toolMetric('ย้ายออก/วันนี้', g.outToday)}
        ${toolMetric('รถผ่านเมือง', g.passToday)}
      </div>
      <div class="muted" style="margin-top:8px">รถย้ายเข้าและรถผ่านเมืองอ้างอิงจาก Gate นี้จริง</div>`;
  }
  function inspectBuilding(b) {
    if (!b) return;
    const t = buildingType(b);
    selectionEl.innerHTML = `<div class="inspector-title">${toolIcon('building', t.key)} ${t.name} #${b.id}</div>
      <div class="muted">${t.desc}</div>
      <div class="metric-grid">
        ${toolMetric('ขนาด', `${t.w}x${t.h}`)}
        ${toolMetric('บำรุง', `${formatMoney(t.maintenance)}/วัน`)}
        ${toolMetric('คนอยู่', `${b.residents}/${t.residents || 0}${b.reservedResidents ? ` (+จอง ${b.reservedResidents})` : ''}`)}
        ${toolMetric('คนทำงาน', `${b.employees}/${t.jobs}`)}
        ${toolMetric('ผู้ใช้บริการ', `${b.visitors}/${t.service}${b.reservedService ? ` (+จอง ${b.reservedService})` : ''}`)}
        ${toolMetric('วันนี้', `ถึง ${b.arrivals} • Fail ${b.fails}`)}
      </div>
      <div class="muted" style="margin-top:8px">Entrance: ${xy(b.entrance).x}, ${xy(b.entrance).y} • อาคารนี้ถูกใช้โดย Trip/Capacity จริง</div>`;
  }
  function inspectRoad(x, y) {
    const i = idx(x,y);
    const r = roadDataById(road[i]);
    const ratio = getRoadRatio(i);
    const carsHere = cellVehicleCount(i);
    const types = {};
    for (const v of vehicles) if (v.currentIdx === i || v.nextIdx === i) types[v.type] = (types[v.type]||0) + 1;
    selectionEl.innerHTML = `<div class="inspector-title">🛣️ ถนน ${x}, ${y}</div>
      <div class="muted">${r.name} • ${r.lanes} เลน • ${connCache[i]>=3 ? 'ทางแยก 4 ขา/ไฟแดง' : 'ทางถนน'}</div>
      <div class="metric-grid">
        ${toolMetric('รถบนช่อง', `${carsHere}/${r.lanes} คัน`)}
        ${toolMetric('Capacity', `${r.capacity} คัน/ช่อง`)}
        ${toolMetric('Traffic Ratio', ratio.toFixed(2))}
        ${toolMetric('สถานะ', `<span style="color:${trafficColor(ratio)}">${roadStatus(ratio)}</span>`)}
        ${toolMetric('ทางเชื่อม', `${connCache[i]} ขา`)}
        ${toolMetric('ค่ารอ', waitLoad[i].toFixed(1))}
      </div>
      <div class="muted" style="margin-top:8px">Trip: ${Object.entries(types).map(([k,v])=>`${k} ${v}`).join(', ') || '-'} • เปิด Heatmap เพื่อดูเขียว/เหลือง/ส้ม/แดง/ดำ</div>`;
  }
  function roadStatus(r) { return r<=.6?'ไหลดี':r<=.9?'เริ่มหนาแน่น':r<=1.2?'ติด':r<=1.6?'ติดหนัก':'Gridlock'; }

  function pointerPos(e) {
    const rect = canvas.getBoundingClientRect();
    return { x: e.clientX - rect.left, y: e.clientY - rect.top };
  }

  canvas.addEventListener('mousemove', (e) => {
    const p = pointerPos(e);
    game.lastMouse = p;
    const g = screenToGrid(p.x, p.y);
    game.hover = inBounds(g.x, g.y) ? g : null;
    if (game.draggingPan) {
      game.pan.x += p.x - game.mouseWorld.x;
      game.pan.y += p.y - game.mouseWorld.y;
      game.mouseWorld = p;
    }
  });
  canvas.addEventListener('mousedown', (e) => {
    const p = pointerPos(e);
    if (e.button === 1 || e.button === 2) {
      game.draggingPan = true; game.mouseWorld = p; canvas.classList.add('dragging'); return;
    }
  });
  window.addEventListener('mouseup', (e) => {
    if (game.draggingPan) { game.draggingPan = false; canvas.classList.remove('dragging'); }
  });
  canvas.addEventListener('contextmenu', e => e.preventDefault());

  canvas.addEventListener('click', (e) => {
    if (e.button !== 0) return;
    const p = pointerPos(e);
    const g = screenToGrid(p.x, p.y);
    if (!inBounds(g.x,g.y)) return;
    const tool = game.selectedTool;
    if (!tool) { inspectAt(g.x, g.y); return; }
    if (tool.type === 'road') {
      if (!game.roadStart) { game.roadStart = g; setStatus('เลือกจุดปลายของถนน'); return; }
      const cells = getLineCells(game.roadStart.x, game.roadStart.y, g.x, g.y);
      const valid = canAddRoadCells(cells);
      const cost = estimateRoadCost(cells, tool.key);
      if (!valid.ok) { setStatus(`สร้างไม่ได้: ${valid.reason}`); game.roadStart = null; return; }
      if (!canSpend(cost)) { setStatus('สร้างไม่ได้: เงินไม่พอหรือกำลังติดลบ'); game.roadStart = null; return; }
      placeRoadCells(cells, tool.key, true);
      setStatus(`สร้าง/อัปเกรดถนน ${cells.length} ช่อง ราคา ${formatMoney(cost)} บาท`);
      game.roadStart = null;
      updateToolButtons();
    } else if (tool.type === 'demolishRoad') {
      if (!game.roadStart) { game.roadStart = g; setStatus('เลือกจุดปลายของเส้นถนนที่จะรื้อ'); return; }
      const cells = getLineCells(game.roadStart.x, game.roadStart.y, g.x, g.y);
      let removed = 0;
      for (const i of cells) { const p2 = xy(i); if (removeRoadCell(p2.x, p2.y, true)) removed++; }
      setStatus(`รื้อถนน ${removed} ช่อง`);
      game.roadStart = null;
    } else if (tool.type === 'building') {
      const res = addBuilding(tool.key, g.x, g.y, true);
      if (!res.ok) setStatus(`วางไม่ได้: ${res.reason}`);
      updateToolButtons();
    }
  });

  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    const p = pointerPos(e);
    const before = screenToWorld(p.x, p.y);
    const factor = e.deltaY < 0 ? 1.12 : 0.89;
    game.zoom = clamp(game.zoom * factor, 0.22, 5.2);
    const after = screenToWorld(p.x, p.y);
    game.pan.x += (after.x - before.x) * TILE * game.zoom;
    game.pan.y += (after.y - before.y) * TILE * game.zoom;
  }, { passive: false });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { game.selectedTool = null; game.roadStart = null; updateToolButtons(); showToolInfo(); }
    if (e.key === 'r' || e.key === 'R') { game.selectedTool = {type:'road', key:'small'}; updateToolButtons(); showToolInfo(); }
    if (e.key === 't' || e.key === 'T') { game.selectedTool = {type:'road', key:'medium'}; updateToolButtons(); showToolInfo(); }
    if (e.key === 'y' || e.key === 'Y') { game.selectedTool = {type:'road', key:'large'}; updateToolButtons(); showToolInfo(); }
    const step = 35;
    if (e.key === 'ArrowLeft' || e.key === 'a') game.pan.x += step;
    if (e.key === 'ArrowRight' || e.key === 'd') game.pan.x -= step;
    if (e.key === 'ArrowUp' || e.key === 'w') game.pan.y += step;
    if (e.key === 'ArrowDown' || e.key === 's') game.pan.y -= step;
  });

  document.querySelectorAll('.speedBtn').forEach(btn => btn.addEventListener('click', () => {
    game.speed = Number(btn.dataset.speed);
    game.skipMode = false;
    updateSpeedButtons();
  }));
  function updateSpeedButtons() {
    document.querySelectorAll('.speedBtn').forEach(btn => btn.classList.toggle('active', Number(btn.dataset.speed) === game.speed && !game.skipMode));
  }
  document.getElementById('skipBtn').addEventListener('click', () => {
    const target = absAt(absDay() + 1, 6*60);
    game.speed = 25;
    game.skipMode = true;
    addAlert('กำลังข้ามวัน', `ประมวลผล Simulation Summary ไปยัง ${DAY_NAMES[(absDay()+1)%7]} 06:00`, 1, 'good');
    // guard: if player clicks at early morning, still use high-speed forward simulation with rendering throttled normally
    if (game.worldMin > target) game.worldMin = target - 10;
    updateSpeedButtons();
  });
  heatBtn.addEventListener('click', () => { game.heatmap = !game.heatmap; heatBtn.textContent = `🌡 Heatmap: ${game.heatmap ? 'เปิด' : 'ปิด'}`; });
  debugBtn.addEventListener('click', () => { game.debug = !game.debug; debugBtn.textContent = `🧪 Debug: ${game.debug ? 'เปิด' : 'ปิด'}`; });
  document.getElementById('resetBtn').addEventListener('click', () => resetCity(citySelect.value));
  citySelect.addEventListener('change', () => resetCity(citySelect.value));

  let last = performance.now();
  let uiTick = 0;
  function loop(now) {
    const dt = Math.min(0.05, (now - last) / 1000);
    last = now;
    update(dt);
    draw();
    uiTick += dt;
    if (uiTick > 0.33) {
      uiTick = 0;
      renderStats();
      renderAlerts();
      updateToolButtons();
      const s = computeStats();
      statusText.textContent = `${timeText()} • รถ ${s.activeTrips} • ถนน ${game.roadCount} ช่อง • Heatmap ${game.heatmap?'ON':'OFF'} • Debug ${game.debug?'ON':'OFF'}`;
    }
    requestAnimationFrame(loop);
  }

  buildToolButtons();
  resetCity('phuket');
  showToolInfo();
  requestAnimationFrame(loop);
})();
