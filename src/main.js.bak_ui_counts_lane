  function roadDataById(id) { return ROAD_BY_ID[id] || null; }
  function getRoadRatio(i) {
    const t = road[i];
    if (!t) return 0;
    const rd = roadDataById(t);
    const usage = flowLoad[i] * 0.75 + waitLoad[i] * 7 + cellVehicleCount(i) * 4;
    return usage / rd.capacity;
  }
  function trafficColor(ratio) {
